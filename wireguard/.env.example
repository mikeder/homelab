# Public hostname or IP that WireGuard clients will connect to (UDP port 51820).
# This is also used to generate client configs — set it to your server's public IP or DNS name.
WG_HOST=vpn.example.com

# Domain for the wg-easy web UI (via Traefik HTTPS).
WG_UI_DOMAIN=vpn.example.com

# Bcrypt hash of the admin password for the wg-easy web UI.
# Generate with: docker run --rm -it ghcr.io/wg-easy/wg-easy wgpw 'YOUR_PASSWORD'
# Then paste the output here (the $2b$... hash string).
WG_ADMIN_PASSWORD_HASH=
